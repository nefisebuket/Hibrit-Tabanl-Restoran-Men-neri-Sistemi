<!DOCTYPE html>
<html class="light" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Digital Concierge</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              colors: {
                "secondary-fixed": "#5cfcd0",
                "secondary-dim": "#005b47",
                "primary-container": "#00feaf",
                "on-secondary-fixed": "#004939",
                "error-container": "#fb5151",
                "on-secondary-fixed-variant": "#006852",
                "outline-variant": "#abadae",
                "tertiary-dim": "#005865",
                "tertiary-container": "#00e0ff",
                "on-background": "#2c2f30",
                "secondary-container": "#ff0a218f",
                "surface-container-high": "#e0e3e4",
                "primary-dim": "#005c3d",
                "surface-variant": "#dadddf",
                "primary-fixed": "#00feaf",
                "secondary-fixed-dim": "#49edc3",
                "on-surface": "#2c2f30",
                "primary": "#006946",
                "surface-bright": "#f5f6f7",
                "surface-container-low": "#eff1f2",
                "inverse-surface": "#0c0f10",
                "inverse-on-surface": "#9b9d9e",
                "on-secondary": "#c5ffe9",
                "surface-container": "#e6e8ea",
                "on-error": "#ffefee",
                "on-error-container": "#570008",
                "surface-dim": "#d1d5d7",
                "inverse-primary": "#00feaf",
                "on-primary-fixed-variant": "#006745",
                "surface-tint": "#006946",
                "tertiary-fixed": "#00e0ff",
                "on-primary-container": "#005c3d",
                "tertiary": "#006574",
                "background": "#f5f6f7",
                "surface-container-lowest": "#ffffff",
                "on-surface-variant": "#595c5d",
                "tertiary-fixed-dim": "#00d1ee",
                "primary-fixed-dim": "#00eea4",
                "on-secondary-container": "#005d49",
                "secondary": "#006852",
                "on-tertiary-container": "#004b57",
                "on-tertiary-fixed": "#00363f",
                "error": "#b31b25",
                "on-tertiary": "#dbf8ff",
                "on-tertiary-fixed-variant": "#005562",
                "on-primary-fixed": "#00472e",
                "outline": "#757778",
                "surface": "#f5f6f7",
                "on-primary": "#c9ffdf",
                "error-dim": "#9f0519",
                "surface-container-highest": "#dadddf"
              },
              fontFamily: {
                "headline": ["Plus Jakarta Sans"],
                "body": ["Inter"],
                "label": ["Inter"]
              },
              borderRadius: {"DEFAULT": "1rem", "lg": "2rem", "xl": "3rem", "full": "9999px"},
            },
          },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>
<body class="bg-surface font-body text-on-surface min-h-screen">
    <nav class="fixed top-0 w-full z-50 bg-white/70 backdrop-blur-xl shadow-sm font-plus-jakarta-sans antialiased flex justify-between items-center px-6 py-4 max-w-full mx-auto">
        <div class="flex items-center gap-8">
            <span class="text-xl font-bold text-emerald-800 tracking-tight">Menus</span>
            <div class="hidden md:flex gap-6">
                <a class="text-emerald-700 border-b-2 border-emerald-500 pb-1 font-semibold" asp-controller="Home" asp-action="Index">Home</a>
                @* <a class="text-zinc-500 hover:text-emerald-600 transition-colors" href="#">Nearby</a> *@
                @* <a class="text-zinc-500 hover:text-emerald-600 transition-colors" href="#">Analytics</a> *@
                @* <a class="text-zinc-500 hover:text-emerald-600 transition-colors" href="#">Upload</a> *@
            </div>
        </div>
        <div class="flex items-center gap-4">
            <button class="p-2 hover:bg-emerald-50/50 rounded-full transition-all active:scale-95 duration-150 ease-in-out">
                <span class="material-symbols-outlined text-zinc-600">notifications</span>
            </button>
            <button class="p-2 hover:bg-emerald-50/50 rounded-full transition-all active:scale-95 duration-150 ease-in-out">
                <span class="material-symbols-outlined text-zinc-600">account_circle</span>
            </button>
        </div>
    </nav>

    <div class="flex pt-20">
        <aside class="h-screen w-64 fixed left-0 top-0 hidden md:flex flex-col bg-zinc-50 pt-24 pb-8 gap-2 font-plus-jakarta-sans text-sm">
            <a class="bg-emerald-100/50 text-emerald-800 rounded-full mx-2 px-4 py-3 font-medium flex items-center gap-3 translate-x-1 duration-200" href="#">
                <span class="material-symbols-outlined">explore</span> Discover
            </a>
            <a class="text-zinc-600 px-4 py-3 mx-2 flex items-center gap-3 hover:bg-zinc-200/50 rounded-full transition-all" href="#">
                <span class="material-symbols-outlined">restaurant</span> Orders
            </a>
            <a class="text-zinc-600 px-4 py-3 mx-2 flex items-center gap-3 hover:bg-zinc-200/50 rounded-full transition-all" href="#">
                <span class="material-symbols-outlined">favorite</span> Favorites
            </a>
            <a class="text-zinc-600 px-4 py-3 mx-2 flex items-center gap-3 hover:bg-zinc-200/50 rounded-full transition-all" href="#">
                <span class="material-symbols-outlined">insights</span> Reviews
            </a>
            <div class="mt-4 flex flex-col gap-1 border-t border-zinc-200 pt-4">
                <a class="text-zinc-500 px-4 py-2 mx-2 flex items-center gap-3 hover:bg-zinc-200/50 rounded-full transition-all" href="#">
                    <span class="material-symbols-outlined text-sm">settings</span> Settings
                </a>
                <a class="text-zinc-500 px-4 py-2 mx-2 flex items-center gap-3 hover:bg-zinc-200/50 rounded-full transition-all" href="#">
                    <span class="material-symbols-outlined text-sm">help_outline</span> Help
                </a>
            </div>
        </aside>

        <main class="flex-1 md:ml-64 p-6 md:p-10 space-y-12">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
    @await Html.PartialAsync("_Chatbot")
    <script src="~/js/chatbot.js"></script>
</body>
</html>